@using DtosProject.DTOs
@model ClientDetailsDTO

@{
    ViewData["Title"] = "Видалити клієнта";
}

<h1>Видалення клієнта</h1>

<div class="alert alert-danger">
    <h3>Ви впевнені, що хочете видалити цього клієнта?</h3>
</div>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">ПІБ</dt>
        <dd class="col-sm-10">@Model.FullName</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Вік</dt>
        <dd class="col-sm-10">@Model.Age</dd>
    </dl>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Підтвердити видалення" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
</form>